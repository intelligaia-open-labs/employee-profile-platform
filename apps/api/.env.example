# API service environment variables
# Copy to .env and fill in real values. Never commit .env.

# --- Database ---
# Postgres connection string. Local default uses Docker / local Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/business_profile?schema=public"

# --- Auth ---
# JWT signing secret. MUST be at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-random-48-byte-hex-string-min-32-chars"

# --- Network ---
PORT=4000
CORS_ORIGIN="http://localhost:3000"
BASE_URL="http://localhost:4000"
PUBLIC_URL="http://localhost:3000"
NODE_ENV="development"

# --- Brand (used in vCard ORG line; defaults to "Your Company" if unset) ---
# Keep this in sync with NEXT_PUBLIC_BRAND_NAME in apps/web/.env.local.
COMPANY_NAME="Your Company Inc."

# --- AWS S3 (optional — leave blank to fall back to local uploads/ folder) ---
# If using S3, create an IAM user with PutObject/GetObject on the bucket only.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
