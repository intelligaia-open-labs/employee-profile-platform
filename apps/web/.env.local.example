# Web app environment variables
# Copy to .env.local and fill in. Never commit .env.local.

# Base URL for the API service. Use http://localhost:4000 for local dev.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Brand (optional; safe defaults render "Your Company" / example.com) ---
# All NEXT_PUBLIC_BRAND_* values appear on the public profile pages.
# Replace the logo files at apps/web/public/profile/logo.svg and logo-dark.svg
# with your own, or point NEXT_PUBLIC_BRAND_LOGO_* at different paths / URLs.

NEXT_PUBLIC_BRAND_NAME="Your Company Inc."
NEXT_PUBLIC_BRAND_SHORT_NAME="Your Company"
NEXT_PUBLIC_BRAND_WEBSITE="example.com"
NEXT_PUBLIC_BRAND_TAGLINE=""
NEXT_PUBLIC_BRAND_SUBTITLE=""

# Multi-line address. Use \n between lines. Leave blank to hide the address block.
NEXT_PUBLIC_BRAND_ADDRESS=""

# Optional Google / Apple Maps link for the "Get directions" button.
NEXT_PUBLIC_BRAND_MAP_URL=""

# Paths or absolute URLs to the logos shown on profile pages.
NEXT_PUBLIC_BRAND_LOGO_LIGHT="/profile/logo.svg"
NEXT_PUBLIC_BRAND_LOGO_DARK="/profile/logo-dark.svg"
