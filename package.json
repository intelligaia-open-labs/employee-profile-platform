{
  "name": "business-profile",
  "version": "1.0.0",
  "description": "Employee profile platform — public profiles, QR codes, vCard, and per-employee analytics. Source-available under ISAL v1.0.",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "author": "Intelligaia (https://www.intelligaia.com/)",
  "homepage": "https://github.com/intelligaia-open-labs/employee-profile-platform#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intelligaia-open-labs/employee-profile-platform.git"
  },
  "bugs": {
    "url": "https://github.com/intelligaia-open-labs/employee-profile-platform/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build -w packages/shared && npm run build -w packages/db && npm run build -w apps/api && npm run build -w apps/web",
    "db:generate": "npm run generate -w packages/db",
    "db:push": "npm run push -w packages/db",
    "db:seed": "npm run seed -w packages/db"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
