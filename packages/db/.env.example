# DB package environment variables (used by Prisma CLI)
# Copy to .env and fill in. Never commit .env.
# Must match DATABASE_URL in apps/api/.env

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/business_profile?schema=public"

# --- Seed admin (optional; only read by `npm run db:seed`) ---
# If unset, the seed creates admin@example.com / changeme-local-only and
# refuses to run in NODE_ENV=production. Set these to seed a real admin.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
